generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CardRequest {
  id             String   @id
  document_type  String   @unique
  email          String
  age            Int
  card_type      String
  currency       String
  status         String
  force_error    Boolean
  correlation_id String
  created_at     DateTime
  updated_at     DateTime

  @@map("card_requests")
}
